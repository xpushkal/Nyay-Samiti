# Environment Configuration for Nyay-Samiti Legal AI

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Model Paths
CHECKPOINT_DIR=./checkpoints
NER_MODEL_PATH=./checkpoints/legalbert_inlegalner
CUAD_MODEL_PATH=./checkpoints/legalbert_cuad_classifier/checkpoint-1600
SUMMARIZATION_MODEL_PATH=./checkpoints/bart_billsum_finetuned/final
RISK_MODEL_PATH=./checkpoints/legalbert_risk_scorer/final
COMPARISON_MODEL_PATH=./checkpoints/legal_comparison_model
RECOMMENDATIONS_MODEL_PATH=./checkpoints/t5_recommendations/final
QA_MODEL_PATH=./checkpoints/legalbert_qa/final

# Dataset Paths
DATASET_DIR=./model_development/datasets
CUAD_DATASET_PATH=./model_development/datasets/CUAD_full
NER_DATASET_PATH=./model_development/datasets/LegalNER_full

# Training Configuration
MAX_EPOCHS=3
BATCH_SIZE=8
LEARNING_RATE=2e-5
MAX_LENGTH=512

# Device Configuration (auto-detected by default)
# DEVICE=mps  # For Apple Silicon
# DEVICE=cuda  # For NVIDIA GPUs
# DEVICE=cpu   # For CPU-only

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Optional: Hugging Face
# HF_TOKEN=your_huggingface_token_here
# HF_CACHE_DIR=~/.cache/huggingface

# Optional: Weights & Biases (for training monitoring)
# WANDB_API_KEY=your_wandb_key_here
# WANDB_PROJECT=nyay-samiti
# WANDB_ENTITY=your_username

# Security (for production)
# API_KEY=your_secure_api_key
# JWT_SECRET=your_jwt_secret
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
